# @TODO: finish replacing the colors here


# Menu
menu.border.color: #000000

menu.title.bg: Solid Flat
menu.title.bg.color: #ff90ff
menu.title.bg.shadow: 0
menu.title.text.color: #000000
menu.title.text.justify: Center

menu.items.bg: Solid Flat
menu.items.bg.color: #ff90ff
menu.items.text.color: #000000
menu.items.disabled.text.color: #3f243f

menu.items.active.bg: Solid Flat
menu.items.active.bg.color: #ff7aff
menu.items.active.text.color: #000000

menu.separator.color: #3f243f
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4

# Window focused
window.active.title.separator.color: #ff90ff

# Active window
window.active.border.color: #ff90ff


window.active.title.bg: flat solid
window.active.title.bg.color: #ff90ff
window.active.title.separator.color: #ff90ff
window.active.text.justify: center

window.active.label.bg: parentrelative
window.active.label.text.color: #000000

window.active.handle.bg: flat solid
window.active.handle.bg.color: #ff90ff

window.active.grip.bg: flat solid
window.active.grip.bg.color: #ff90ff

window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #ff90ff
window.active.button.unpressed.image.color: #000000

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #ff7aff
window.active.button.pressed.image.color: #000000

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #ff90ff
window.active.button.disabled.image.color: #3f243f

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #ff90ff
window.active.button.hover.image.color: #ff7aff

#window.active.button.toggled.bg: #ff7aff
#window.active.button.toggled.image.color: #000000

# Inactive window
window.inactive.border.color: #000000

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #ff90ff
window.inactive.title.separator.color: #ff90ff
window.inactive.text.justify: center

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #3f243f

window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #ff90ff

window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #ff90ff

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #ff90ff
window.inactive.button.unpressed.image.color: #3f243f

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #ff7aff
window.inactive.button.pressed.image.color: #000000

window.inactive.button.disabled.bg: flat solid
window.inactive.button.disabled.bg.color: #3f243f
window.inactive.button.disabled.image.color: #ff90ff

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #ff90ff
window.inactive.button.hover.image.color: #ff7aff


# OSD
osd.border.width: 1
osd.border.color: #ff7aff

osd.bg: flat solid
osd.bg.color: #ff90ff
osd.label.bg: flat solid
osd.label.bg.color: #ff90ff
osd.label.text.color: #000000

# OSD
osd.bg: Solid Flat
osd.bg.color: #ff90ff
osd.bg.shadow: 0

osd.border.width: 2
osd.hilight.bg: Solid Flat
osd.hilight.bg.color: #ff7aff
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #ffaaff

osd.button.unpressed.bg: flat border
osd.button.unpressed.bg.color: #ff90ff
#osd.button.unpressed.*.border.color: #000000

osd.button.pressed.bg: flat border
osd.button.pressed.bg.color: #ff7aff
#osd.button.pressed.*.border.color: #000000

osd.button.focused.bg: flat solid border
osd.button.focused.bg.color: #000000
#osd.button.focused.*.border.color: #ffaaff

osd.button.focused.box.color: #ff7aff


# Fonts
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n


# Everything else
border.width: 2
padding.width: 8
padding.height: 2
window.handle.width: 0
window.client.padding.width: 0
window.label.text.justify: center
#menu.overlap: 0
